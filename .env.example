# PostgreSQL (DIRECT access) 
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=transport_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
APP_PORT=5000
LOG_LEVEL=INFO
 

# Routing Engine API 
ROUTING_ENGINE_URL=https://routing-demo-eval.azurewebsites.net
ROUTING_ENGINE_TIMEOUT=30
ROUTING_MAX_TRANSFERS=3
ROUTING_WALKING_CUTOFF=1500
ROUTING_TOP_K=10
 

# AI Model (Intent — Qwen2.5 + LoRA)
MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
MODEL_MAX_NEW_TOKENS=256
MODEL_TEMPERATURE=0.1
MODEL_LORA_ADAPTER_PATH=model/intent/lora_adapter      
MODEL_HF_LORA_REPO=Elbana22/transport-agent-intent-lora

# Fare Model
FARE_MODEL_PATH=model/fare/model.pkl
FARE_HF_REPO=  

# HuggingFace Tokens   
HF_READ_TOKEN=hf_your_read_token_here
HF_WRITE_TOKEN=hf_your_write_token_here
 

# Geo Tool  
GEO_SIMILARITY_THRESHOLD=0.3
GEO_CACHE_SIZE=1000
GEO_NEAREST_STOP_RADIUS_METERS=800
GEO_NOMINATIM_URL=https://nominatim.openstreetmap.org
GEO_NOMINATIM_USER_AGENT=transport-agent-gp/1.0
GEO_NOMINATIM_TIMEOUT=10
 

# App  
APP_ENV=development
APP_PORT=5000
LOG_LEVEL=INFO
MEMORY_WINDOW_SIZE=5
MAX_DISPLAYED_JOURNEYS=3